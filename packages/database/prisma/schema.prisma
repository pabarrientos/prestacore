// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  VENDEDOR
  CLIENTE
}

enum LoanStatus {
  PENDING     // Pendiente de aprobación
  ACTIVE      // Activo
  PAID        // Cancelado/pagado
  DEFAULTED   // En mora/incumplido
  CANCELLED   // Cancelado por el cliente
  REFINANCIADO // Refinanciado (origen de nueva operación)
}

enum PaymentStatus {
  PENDING   // Pendiente
  COMPLETED // Completado
  FAILED    // Fallido
  REFUNDED  // Reembolsado
}

enum PaymentFrequency {
  WEEKLY     // Semanal
  BIWEEKLY   // Quincenal
  MONTHLY    // Mensual
  DAILY      // Diario
}

enum InstallmentStatus {
  PENDING   // Pendiente de pago
  PAID      // Pagado
  OVERDUE   // Vencido
  PARTIAL   // Pago parcial
  CANCELADA_POR_REFINANCIACION // Cancelada por refinanciación
  INTEREST_ONLY // Pago de solo interés (cuota cerrada, capital pendiente se movió a nueva cuota)
}

enum CollectionActionType {
  CALL        // Llamada telefónica
  VISIT       // Visita presencial
  AGREEMENT   // Acuerdo de pago
  REFINANCING // Refinanciación
  LEGAL       // Acción legal
  PROMISE     // Promesa de pago
}

enum AmortizationSystemType {
  FRENCH    // Sistema Francés: cuota fija, interés sobre saldo decreciente
  GERMAN    // Sistema Alemán: capital constante, interés sobre saldo restante
  FLAT_RATE // Sistema Tasa Plana: interés sobre capital original
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  DEPOSITO
  CHEQUE
  TARJETA
  MOVIMIENTO_REFINANCIACION // Movimiento generado por refinanciación
}

enum CommissionMode {
  PROPORTIONAL              // Commission on interest from each installment collected
  AFTER_CAPITAL_RECOVERY    // Commission only after capital fully recovered
  ADVANCED                  // Weighted commission (early installments weighted more)
}

enum LiquidationType {
  PAYMENT   // Normal liquidation (pago de comisiones)
  ADVANCE   // Adelanto (excede el pendiente disponible)
  REFUND    // Devolución del vendedor (reduce lo liquidado)
}

// ============================================
// MODELS
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(CLIENTE)
  firstName     String
  lastName      String
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Commission configuration (only meaningful for VENDEDOR role)
  commissionPercentage Decimal?  @db.Decimal(7, 4) // 0-100, 4 decimal places
  commissionMode      CommissionMode?

  // Relations
  client        Client?
  assignedLoans Loan[]    @relation("AssignedLoans")
  // Seller relations for commission system
  sellerLiquidations      SellerLiquidation[] @relation("SellerLiquidations")
  sellerCommissionAudits  SellerCommissionAudit[] @relation("SellerCommissionAuditVendor")
  createdLiquidations    SellerLiquidation[] @relation("SellerLiquidationsCreatedBy")
  createdAudits          SellerCommissionAudit[] @relation("SellerCommissionAuditCreatedBy")

  @@index([email])
  @@index([role])
}

model Client {
  id              String    @id @default(cuid())
  userId          String    @unique
  dni             String    @unique
  dateOfBirth     DateTime
  address         String?
  city            String?
  occupation      String?
  employer        String?
  monthlyIncome   Decimal   @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  loans           Loan[]
  payments        Payment[]
  collectionActions CollectionAction[]

  @@index([dni])
}

model Loan {
  id                String        @id @default(cuid())
  clientId          String
  assignedVendorId  String?
  amount            Decimal       @db.Decimal(12, 2)
  interestRate      Decimal       @db.Decimal(7, 4) // Tasa anual (soporta hasta 999.9999%)
  termMonths        Int           // Número de pagos (semanas/quincenas/meses según frecuencia)
  frequency         PaymentFrequency @default(MONTHLY)
  status            LoanStatus    @default(PENDING)
  amortizationSystem AmortizationSystemType @default(FRENCH)
  purpose           String?
  notes             String?
  approvedAt        DateTime?
  approvedBy        String?
  startedAt         DateTime?     // Fecha de inicio del préstamo
  completedAt       DateTime?     // Fecha de finalización
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Calculated fields (cached for performance)
  totalInterest     Decimal       @db.Decimal(12, 2)
  totalPayment     Decimal       @db.Decimal(12, 2)
  installmentAmount Decimal       @db.Decimal(12, 2)

  // Refinancing fields
  prestamo_origen_id      String?   @unique // ID del préstamo original (si este es el nuevo préstamo refinanciado)
  prestamo_refinanciado   Loan?    @relation("Refinanciacion", fields: [prestamo_origen_id], references: [id])
  prestamo_origen         Loan?    @relation("Refinanciacion")
  prestamo_nuevo_id       String?   // ID del nuevo préstamo (si este es el préstamo original refinanciado)

  // Commission fields (snapshotted from seller defaults at loan creation)
  commissionPercentage    Decimal?  @db.Decimal(7, 4)  // Seller's percentage at time of loan
  commissionMode          CommissionMode?              // Seller's mode at time of loan
  commissionProjected     Decimal?  @db.Decimal(12, 2) // Projected total commission at creation
  commissionGenerated     Decimal?  @db.Decimal(12, 2) @default(0) // Actual commission earned
  commissionLiquidated    Decimal?  @db.Decimal(12, 2) @default(0) // Commission already liquidated

  // Relations
  client           Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedVendor   User?         @relation("AssignedLoans", fields: [assignedVendorId], references: [id])
  installments     Installment[]
  payments         Payment[]
  collectionActions CollectionAction[]

  @@index([clientId])
  @@index([status])
  @@index([assignedVendorId])
  @@index([prestamo_origen_id])
  @@index([prestamo_nuevo_id])
}

model Installment {
  id              String            @id @default(cuid())
  loanId          String
  installmentNumber Int
  dueDate         DateTime
  amount          Decimal           @db.Decimal(12, 2)
  principal       Decimal           @db.Decimal(12, 2)
  interest        Decimal           @db.Decimal(12, 2)
  balance         Decimal           @db.Decimal(12, 2)
  capitalBalance  Decimal           @db.Decimal(12, 2)  // Saldo capital (capital pendiente)
  status          InstallmentStatus @default(PENDING)
  paidAt          DateTime?
  paidAmount      Decimal           @db.Decimal(12, 2) @default(0)
  interestCollected Decimal         @db.Decimal(12, 2) @default(0) // Acumulado de interés cobrado vía pagos de solo-interés
  moraAmount      Decimal           @db.Decimal(12, 2) @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  loan            Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)
  payments        Payment[]

  @@index([loanId])
  @@index([dueDate])
  @@index([status])
}

model Payment {
  id              String        @id @default(cuid())
  clientId        String
  loanId          String
  installmentId   String?
  amount          Decimal       @db.Decimal(12, 2)
  type            String        // MANUAL, AUTOMATIC, BATCH
  method          PaymentMethod? // EFECTIVO, TRANSFERENCIA, etc.
  status          PaymentStatus @default(PENDING)
  reference       String?       // Número de transacción, comprobante
  notes           String?
  paymentDate    DateTime?     // Fecha real del pago ( editable)
  processedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  loan            Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  installment     Installment?  @relation(fields: [installmentId], references: [id])

  @@index([loanId])
  @@index([clientId])
  @@index([status])
}

model CollectionAction {
  id              String              @id @default(cuid())
  loanId          String
  clientId        String
  type            String              // Código del tipo (ej: CALL, VISIT, WHATSAPP, etc.)
  description     String
  result          String?
  nextAction      String?             // Próxima acción a tomar (código del tipo)
  followUpDate    DateTime?           // Fecha de seguimiento
  createdAt       DateTime            @default(now())
  createdBy       String?

  // Relations
  loan            Loan                @relation(fields: [loanId], references: [id], onDelete: Cascade)
  client          Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([clientId])
  @@index([createdAt])
}

// Sistema de configuración
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}

// Auditoría
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entity      String   // User, Loan, Payment, etc.
  entityId    String?
  changes     Json?    // Datos anteriores/nuevos
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}

// Seller Commission Liquidation
model SellerLiquidation {
  id          String   @id @default(cuid())
  sellerId    String   // Vendor whose commissions are being liquidated
  amount      Decimal  @db.Decimal(12, 2)
  type        LiquidationType @default(PAYMENT)
  notes       String?
  createdBy   String   // Admin who created this liquidation
  createdAt   DateTime @default(now())

  // Relations
  seller      User     @relation("SellerLiquidations", fields: [sellerId], references: [id])
  creator     User     @relation("SellerLiquidationsCreatedBy", fields: [createdBy], references: [id])

  @@index([sellerId])
  @@index([createdAt])
}

// ============================================
// Backup Management
// ============================================

model Backup {
  id         String   @id @default(cuid())
  filename   String
  filepath   String
  sizeBytes  Int
  type       String   // MANUAL | SCHEDULED | UPLOADED
  status     String   // COMPLETED | FAILED | RESTORING
  checksum   String?  // SHA-256 hash
  tablesMeta Json?    // Array<{name: string, rowCount: number}>
  error      String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([type])
}

// ============================================
// Seller Commission Configuration Audit
// ============================================

model SellerCommissionAudit {
  id          String   @id @default(cuid())
  vendorId    String   // Vendor whose config was changed
  field       String   // Which field was changed: 'commissionPercentage' or 'commissionMode'
  previousValue String // Previous value as string
  newValue     String  // New value as string
  changedBy   String   // Admin who made the change
  createdAt   DateTime @default(now())

  // Relations
  vendor      User     @relation("SellerCommissionAuditVendor", fields: [vendorId], references: [id])
  changer     User     @relation("SellerCommissionAuditCreatedBy", fields: [changedBy], references: [id])

  @@index([vendorId])
  @@index([createdAt])
}
