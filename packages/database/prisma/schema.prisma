// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  VENDEDOR
  CLIENTE
}

enum LoanStatus {
  PENDING     // Pendiente de aprobación
  ACTIVE      // Activo
  PAID        // Cancelado/pagado
  DEFAULTED   // En mora/incumplido
  CANCELLED   // Cancelado por el cliente
  REFINANCIADO // Refinanciado (origen de nueva operación)
}

enum PaymentStatus {
  PENDING   // Pendiente
  COMPLETED // Completado
  FAILED    // Fallido
  REFUNDED  // Reembolsado
}

enum PaymentFrequency {
  WEEKLY     // Semanal
  BIWEEKLY   // Quincenal
  MONTHLY    // Mensual
  DAILY      // Diario
}

enum InstallmentStatus {
  PENDING   // Pendiente de pago
  PAID      // Pagado
  OVERDUE   // Vencido
  PARTIAL   // Pago parcial
  CANCELADA_POR_REFINANCIACION // Cancelada por refinanciación
}

enum CollectionActionType {
  CALL        // Llamada telefónica
  VISIT       // Visita presencial
  AGREEMENT   // Acuerdo de pago
  REFINANCING // Refinanciación
  LEGAL       // Acción legal
  PROMISE     // Promesa de pago
}

enum PaymentMethod {
  EFECTIVO
  TRANSFERENCIA
  DEPOSITO
  CHEQUE
  TARJETA
  MOVIMIENTO_REFINANCIACION // Movimiento generado por refinanciación
}

// ============================================
// MODELS
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(CLIENTE)
  firstName     String
  lastName      String
  phone         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  client        Client?
  assignedLoans Loan[]    @relation("AssignedLoans")

  @@index([email])
  @@index([role])
}

model Client {
  id              String    @id @default(cuid())
  userId          String    @unique
  dni             String    @unique
  dateOfBirth     DateTime
  address         String?
  city            String?
  occupation      String?
  employer        String?
  monthlyIncome   Decimal   @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  loans           Loan[]
  payments        Payment[]
  collectionActions CollectionAction[]

  @@index([dni])
}

model Loan {
  id                String        @id @default(cuid())
  clientId          String
  assignedVendorId  String?
  amount            Decimal       @db.Decimal(12, 2)
  interestRate      Decimal       @db.Decimal(7, 4) // Tasa anual (soporta hasta 999.9999%)
  termMonths        Int           // Número de pagos (semanas/quincenas/meses según frecuencia)
  frequency         PaymentFrequency @default(MONTHLY)
  status            LoanStatus    @default(PENDING)
  purpose           String?
  notes             String?
  approvedAt        DateTime?
  approvedBy        String?
  startedAt         DateTime?     // Fecha de inicio del préstamo
  completedAt       DateTime?     // Fecha de finalización
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Calculated fields (cached for performance)
  totalInterest     Decimal       @db.Decimal(12, 2)
  totalPayment     Decimal       @db.Decimal(12, 2)
  installmentAmount Decimal       @db.Decimal(12, 2)

  // Refinancing fields
  prestamo_origen_id      String?   @unique // ID del préstamo original (si este es el nuevo préstamo refinanciado)
  prestamo_refinanciado   Loan?    @relation("Refinanciacion", fields: [prestamo_origen_id], references: [id])
  prestamo_origen         Loan?    @relation("Refinanciacion")
  prestamo_nuevo_id       String?   // ID del nuevo préstamo (si este es el préstamo original refinanciado)

  // Relations
  client           Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedVendor   User?         @relation("AssignedLoans", fields: [assignedVendorId], references: [id])
  installments     Installment[]
  payments         Payment[]
  collectionActions CollectionAction[]

  @@index([clientId])
  @@index([status])
  @@index([assignedVendorId])
  @@index([prestamo_origen_id])
  @@index([prestamo_nuevo_id])
}

model Installment {
  id              String            @id @default(cuid())
  loanId          String
  installmentNumber Int
  dueDate         DateTime
  amount          Decimal           @db.Decimal(12, 2)
  principal       Decimal           @db.Decimal(12, 2)
  interest        Decimal           @db.Decimal(12, 2)
  balance         Decimal           @db.Decimal(12, 2)
  capitalBalance  Decimal           @db.Decimal(12, 2)  // Saldo capital (capital pendiente)
  status          InstallmentStatus @default(PENDING)
  paidAt          DateTime?
  paidAmount      Decimal           @db.Decimal(12, 2) @default(0)
  moraAmount      Decimal           @db.Decimal(12, 2) @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  loan            Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)
  payments        Payment[]

  @@index([loanId])
  @@index([dueDate])
  @@index([status])
}

model Payment {
  id              String        @id @default(cuid())
  clientId        String
  loanId          String
  installmentId   String?
  amount          Decimal       @db.Decimal(12, 2)
  type            String        // MANUAL, AUTOMATIC, BATCH
  method          PaymentMethod? // EFECTIVO, TRANSFERENCIA, etc.
  status          PaymentStatus @default(PENDING)
  reference       String?       // Número de transacción, comprobante
  notes           String?
  paymentDate    DateTime?     // Fecha real del pago ( editable)
  processedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  loan            Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)
  installment     Installment?  @relation(fields: [installmentId], references: [id])

  @@index([loanId])
  @@index([clientId])
  @@index([status])
}

model CollectionAction {
  id              String              @id @default(cuid())
  loanId          String
  clientId        String
  type            CollectionActionType
  description     String
  result          String?
  nextAction      String?             // Próxima acción a tomar
  followUpDate    DateTime?           // Fecha de seguimiento
  createdAt       DateTime            @default(now())
  createdBy       String?

  // Relations
  loan            Loan                @relation(fields: [loanId], references: [id], onDelete: Cascade)
  client          Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@index([clientId])
  @@index([createdAt])
}

// Sistema de configuración
model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}

// Auditoría
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entity      String   // User, Loan, Payment, etc.
  entityId    String?
  changes     Json?    // Datos anteriores/nuevos
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
}
