# JWT
JWT_SECRET=your-secret-key-change-in-production

# Web - API URL (se bakea en el bundle de Next.js en build time)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Backup directory on host (mounted as /app/backups in API container)
BACKUPS_HOST_DIR=./storage/backups

# Tenant subdomain prefix (must match tenant slug)
APP_SUBDOMAIN_PREFIX=tenant-default
